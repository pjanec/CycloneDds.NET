@using DdsMonitor.Components
@inherits LayoutComponentBase

@using System.IO
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms

@inject IWindowManager WindowManager
@inject IWorkspaceState WorkspaceState
@inject IJSRuntime JSRuntime
@inject WorkspacePersistenceService WorkspacePersistence

<div class="app-shell">
    <div class="app-toolbar">
        <button type="button" class="app-toolbar__button" @onclick="OpenTopicsPanel">Topics</button>
        <button type="button" class="app-toolbar__button" @onclick="OpenFilterBuilder">Filter Builder</button>
        <button type="button" class="app-toolbar__button" @onclick="ResetLayout">Reset Layout</button>
        <button type="button" class="app-toolbar__button" @onclick="ExportWorkspace">Export Layout</button>
        <label class="app-toolbar__button" for="workspaceImport">Import Layout</label>
        <button type="button" class="app-toolbar__button" @onclick="ToggleTheme">@GetThemeLabel()</button>
    </div>
    <InputFile id="workspaceImport" OnChange="ImportWorkspace" style="display:none" accept=".workspace,application/json" />
    <div class="app-shell__content">
        @Body
    </div>
</div>

@code {
    private static readonly string TopicExplorerTypeName = typeof(TopicExplorerPanel).AssemblyQualifiedName!;
    private static readonly string FilterBuilderTypeName = typeof(FilterBuilderPanel).AssemblyQualifiedName!;
    private const string WorkspaceExportFileName = "ddsmon.workspace";
    private string _theme = "dark";

    private void OpenTopicsPanel()
    {
        foreach (var panel in WindowManager.ActivePanels)
        {
            if (string.Equals(panel.ComponentTypeName, TopicExplorerTypeName, StringComparison.Ordinal))
            {
                panel.IsMinimized = false;
                panel.IsHidden = false;
                WindowManager.BringToFront(panel.PanelId);
                return;
            }
        }

        var newPanel = WindowManager.SpawnPanel(TopicExplorerTypeName);
        newPanel.Title = "Topics";
    }

    private void OpenFilterBuilder()
    {
        foreach (var panel in WindowManager.ActivePanels)
        {
            if (string.Equals(panel.ComponentTypeName, FilterBuilderTypeName, StringComparison.Ordinal))
            {
                panel.IsMinimized = false;
                panel.IsHidden = false;
                WindowManager.BringToFront(panel.PanelId);
                return;
            }
        }

        var newPanel = WindowManager.SpawnPanel(FilterBuilderTypeName);
        newPanel.Title = "Filter Builder";
    }

    private void ResetLayout()
    {
        var filePath = WorkspaceState.WorkspaceFilePath;
        if (!string.IsNullOrWhiteSpace(filePath) && File.Exists(filePath))
        {
            File.Delete(filePath);
        }

        WindowManager.ClearPanels();
        var newPanel = WindowManager.SpawnPanel(TopicExplorerTypeName);
        newPanel.Title = "Topics";

        WorkspacePersistence.SaveNow();
    }

    private async Task ExportWorkspace()
    {
        var json = WorkspacePersistence.ExportWorkspaceJson();
        await JSRuntime.InvokeVoidAsync("ddsMonitor.downloadTextFile", WorkspaceExportFileName, json, "application/json");
    }

    private async Task ImportWorkspace(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file == null)
        {
            return;
        }

        using var stream = file.OpenReadStream(5 * 1024 * 1024);
        using var reader = new StreamReader(stream);
        var json = await reader.ReadToEndAsync();
        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        WorkspacePersistence.ImportWorkspaceJson(json);
        WorkspacePersistence.SaveNow();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _theme = await JSRuntime.InvokeAsync<string>("ddsMonitor.applyStoredTheme");
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        _theme = await JSRuntime.InvokeAsync<string>("ddsMonitor.toggleTheme");
    }

    private string GetThemeLabel()
    {
        return _theme == "light" ? "Theme: Light" : "Theme: Dark";
    }
}
