<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DdsMonitor.Avalonia.ShellWindow"
        Title="DDS Monitor"
        Width="1200"
        Height="800"
        MinWidth="600"
        MinHeight="400">

    <DockPanel>

        <!-- Top menu bar -->
        <Menu x:Name="TopMenu" DockPanel.Dock="Top" />

        <!-- Toolbar -->
        <StackPanel x:Name="Toolbar"
                    DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="4,2" />

        <!-- Transport row -->
        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal"
                    Spacing="4"
                    Margin="4,2">
            <Button x:Name="PlayButton"
                    Content="▶ Play"
                    ToolTip.Tip="Resume recording"
                    Click="OnPlayClick" />
            <Button x:Name="PauseButton"
                    Content="⏸ Pause"
                    ToolTip.Tip="Pause recording"
                    Click="OnPauseClick" />
            <Button x:Name="ResetButton"
                    Content="⏹ Reset"
                    ToolTip.Tip="Reset all data"
                    Click="OnResetClick" />
        </StackPanel>

        <!-- Status bar -->
        <TextBlock x:Name="StatusBar"
                   DockPanel.Dock="Bottom"
                   Text="Ready"
                   Margin="4,2"
                   VerticalAlignment="Center" />

        <!-- Main content area (placeholder for future panels) -->
        <Grid x:Name="ContentArea" />

    </DockPanel>

</Window>
