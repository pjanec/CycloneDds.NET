@using System.Collections.Generic
@using DdsMonitor.Engine
@using DdsMonitor.Plugins.ECS
@inject EntityStore Store
@inject IWindowManager WindowManager
@implements IDisposable

<div class="bdc-entity-grid-panel p-2">
    <div class="d-flex align-items-center mb-2 gap-2">
        <h5 class="mb-0">BDC Entities</h5>
        <div class="btn-group btn-group-sm ms-auto" role="group">
            <button class="btn @(_showLive ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SetView(true)">Live</button>
            <button class="btn @(!_showLive ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SetView(false)">History</button>
        </div>
    </div>

    @if (_showLive)
    {
        <!-- Live entity grid -->
        <table class="table table-sm table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(Entity.EntityId))">
                        Entity ID @SortIndicator(nameof(Entity.EntityId))
                    </th>
                    <th style="cursor:pointer" @onclick="() => SortBy(nameof(Entity.State))">
                        State @SortIndicator(nameof(Entity.State))
                    </th>
                    <th>Descriptors</th>
                    <th>Last Update</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entity in SortedEntities)
                {
                    <tr>
                        <td>@entity.EntityId</td>
                        <td>@StateIcon(entity.State) @entity.State</td>
                        <td>@entity.Descriptors.Count</td>
                        <td>@LatestUpdate(entity)</td>
                        <td>
                            <button class="btn btn-xs btn-outline-secondary"
                                    @onclick="() => OpenDetail(entity)">Detail</button>
                        </td>
                    </tr>
                }
                @if (!SortedEntities.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">No entities yet.</td></tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <!-- History / journal view -->
        <table class="table table-sm table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Entity ID</th>
                    <th>Timestamp</th>
                    <th>New State</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in JournalRows)
                {
                    <tr>
                        <td>@row.EntityId</td>
                        <td>@row.Record.Timestamp.ToString("HH:mm:ss.fff")</td>
                        <td>@StateIcon(row.Record.NewState) @row.Record.NewState</td>
                        <td>@row.Record.Description</td>
                    </tr>
                }
                @if (!JournalRows.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted">No journal entries yet.</td></tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private bool _showLive = true;
    private string _sortColumn = nameof(Entity.EntityId);
    private bool _sortAscending = true;

    private IEnumerable<Entity> SortedEntities
    {
        get
        {
            var entities = Store.Entities.Values;
            IOrderedEnumerable<Entity> ordered = _sortColumn == nameof(Entity.State)
                ? (_sortAscending
                    ? entities.OrderBy(e => e.State)
                    : entities.OrderByDescending(e => e.State))
                : (_sortAscending
                    ? entities.OrderBy(e => e.EntityId)
                    : entities.OrderByDescending(e => e.EntityId));
            return ordered;
        }
    }

    private IEnumerable<(int EntityId, EntityJournalRecord Record)> JournalRows =>
        Store.Entities.Values
             .SelectMany(e => e.Journal.Select(j => (e.EntityId, j)))
             .OrderByDescending(r => r.j.Timestamp)
             .Select(r => (r.EntityId, r.j));

    protected override void OnInitialized()
    {
        Store.Changed += OnStoreChanged;
    }

    public void Dispose()
    {
        Store.Changed -= OnStoreChanged;
    }

    private void OnStoreChanged()
        => InvokeAsync(StateHasChanged);

    private void SetView(bool live)
    {
        _showLive = live;
    }

    private void SortBy(string column)
    {
        if (_sortColumn == column)
            _sortAscending = !_sortAscending;
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string SortIndicator(string column) =>
        _sortColumn != column ? "" : (_sortAscending ? "▲" : "▼");

    private static string StateIcon(EntityState state) => state switch
    {
        EntityState.Alive  => "🟢",
        EntityState.Zombie => "🟡",
        EntityState.Dead   => "⚫",
        _ => ""
    };

    private static string LatestUpdate(Entity entity)
    {
        DateTime latest = DateTime.MinValue;
        foreach (var sample in entity.Descriptors.Values)
        {
            if (sample.Timestamp > latest)
                latest = sample.Timestamp;
        }
        return latest == DateTime.MinValue ? "—" : latest.ToString("HH:mm:ss.fff");
    }

    private void OpenDetail(Entity entity)
    {
        WindowManager.SpawnPanel(
            "BDC Entity Detail",
            new Dictionary<string, object>(StringComparer.Ordinal)
            {
                ["EntityId"] = entity.EntityId
            });
    }
}
