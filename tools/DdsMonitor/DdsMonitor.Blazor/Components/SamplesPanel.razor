@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using System.Text.Json
@using System.IO
@using CycloneDDS.Runtime
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.JSInterop
@using DdsMonitor.Engine.Ui
@implements IDisposable

@inject ISampleStore SampleStore
@inject IFilterCompiler FilterCompiler
@inject IEventBroker EventBroker
@inject IWindowManager WindowManager
@inject IWorkspaceState WorkspaceState
@inject WorkspacePersistenceService WorkspacePersistence
@inject ITopicRegistry TopicRegistry
@inject DdsSettings Settings
@inject TooltipService TooltipService
@inject IJSRuntime JSRuntime
@inject ContextMenuService ContextMenuService
@inject DdsMonitor.Engine.Export.IExportService ExportService

<div class="samples-panel" @onmousemove="HandleColumnResize" @onmouseup="EndColumnResize" @onmouseleave="EndColumnResize">
    <div class="samples-panel__toolbar">
        <button type="button"
                title="Toggle track mode \u2013 auto-selects the latest sample"
                class="samples-panel__track @( _trackMode ? "is-on" : string.Empty)"
                @onclick="ToggleTrackMode">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
        <button type="button" title="Choose visible columns" class="samples-panel__columns" @onclick="ToggleColumnPicker">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="5" height="18" rx="1"/><rect x="10" y="3" width="5" height="18" rx="1"/><rect x="17" y="3" width="4" height="18" rx="1"/></svg>
        </button>
        <button type="button"
                title="Toggle expanded card view"
                class="samples-panel__expand-btn @(_expandAll ? "is-on" : string.Empty)"
                @onclick="ToggleExpandAll">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
        </button>
        <button type="button" title="Open filter builder" class="samples-panel__filter-btn" @onclick="OpenFilterBuilder">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        </button>
        <button type="button" title="Export visible samples to file" class="samples-panel__export-btn" @onclick="ExportFilteredSamplesAsync">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        </button>
        <button type="button" title="Save grid settings to file" class="samples-panel__settings-btn" @onclick="SaveGridSettingsAsync">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </button>
        <label title="Load grid settings from file" class="samples-panel__settings-btn" @onclick:stopPropagation="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <InputFile OnChange="LoadGridSettingsAsync" style="display:none" accept=".samplepanelsettings,application/json" />
        </label>
        <div class="samples-panel__filter">
            <input type="text"
                   value="@_filterText"
                   placeholder="Filter: Payload.Field == 42"
                   @oninput="OnFilterInput" />
        </div>
    </div>

        @if (!string.IsNullOrWhiteSpace(_filterError))
        {
            <div class="samples-panel__error">@_filterError</div>
        }

        <div class="samples-panel__grid" tabindex="0" @ref="_gridRef" @onclick="FocusGrid" @onkeydown="OnGridKeyDown" @onkeydown:preventDefault="true">
            <div class="samples-panel__header" style="@GetGridStyle()">
                @for (var i = 0; i < _layoutColumns.Count; i++)
                {
                    var column = _layoutColumns[i];
                    var isLast = i == _layoutColumns.Count - 1;
                    <div class="samples-panel__header-cell">
                        @if (column.SortField != null)
                        {
                            <button type="button" class="@GetHeaderClass(column.SortField)" @onclick="() => ToggleSort(column.SortField)">
                                @column.Label
                                @GetSortIndicator(column.SortField)
                            </button>
                        }
                        else
                        {
                            <span class="samples-panel__header-label">@column.Label</span>
                        }

                        @if (!isLast)
                        {
                            <div class="samples-panel__resizer"
                                 @onmousedown="(args) => BeginColumnResize(column.Key, args)"
                                 @onmousedown:stopPropagation="true"
                                 @onmousedown:preventDefault="true"></div>
                        }
                    </div>
                }
            </div>

            <Virtualize @ref="_virtualizeRef" ItemsProvider="LoadItems" ItemSize="@(_expandAll ? ExpandedRowHeight : RowHeight)">
                <ItemContent Context="row">
                    @if (_expandAll)
                    {
                        <div class="samples-panel__expand-card" style="height:@(ExpandedRowHeight)px">
                            <div class="samples-panel__expand-card-header">
                                <span class="samples-panel__cell samples-panel__col-ordinal">#@row.Sample.Ordinal</span>
                                <span class="samples-panel__cell samples-panel__col-timestamp">@row.Sample.Timestamp.ToString("HH:mm:ss.fff")</span>
                                <span class="samples-panel__cell @GetStatusClass(row.Sample)" title="@GetStatusTooltip(row.Sample)">@GetStatusSymbol(row.Sample)</span>
                            </div>
                            <pre class="samples-panel__expand-json">@GetPayloadJsonSafe(row.Sample)</pre>
                        </div>
                    }
                    else
                    {
                        <div class="samples-panel__row @(IsSelected(row) ? "is-selected" : string.Empty)" style="@GetGridStyle()"
                            @onclick="() => SelectSample(row, true)"
                            @ondblclick="() => OpenDetail(row.Sample)"
                            @onmousedown="(args) => HandleRowMouseDown(row, args)"
                            @oncontextmenu:preventDefault="true">
                            @foreach (var column in _layoutColumns)
                            {
                                <div class="samples-panel__cell @column.CssClass">
                                    @RenderCellValue(column, row)
                                </div>
                            }
                        </div>
                    }
                </ItemContent>
            </Virtualize>
        </div>

        <div class="samples-panel__status">
            Showing @_currentCount of @_totalCount matching samples
        </div>

    @if (_showColumnPicker)
    {
        <div class="samples-panel__overlay">
            <ColumnPickerDialog @key="_columnPickerRevision"
                                Title="Columns"
                                AvailableFields="@_availableColumns"
                                SelectedFields="@_selectedColumns"
                                OnApply="ApplyColumns"
                                OnCancel="CloseColumnPicker" />
        </div>
    }
    <FileDialog IsOpen="_showExportDialog"
                Mode="FileDialogMode.Save"
                Filter="*.json"
                OnResult="OnExportDialogResult" />
</div>

@code {
    private const int RowHeight = 38;
    private const int ExpandedRowHeight = 200;
    private const int MinimumUiRefreshHz = 1;
    private const int MillisecondsPerSecond = 1000;
    private const string SizeFieldName = "Size [B]";
    private const string DelayFieldName = "Delay [ms]";
    private const int TrackDebounceMs = 25;
    private const int RightMouseButton = 2;
    private const string SelectedColumnsStateKey = "SamplesPanel.SelectedColumns";
    private const string ColumnWeightsStateKey = "SamplesPanel.ColumnWeights";
    private const string FilterTextStateKey = "SamplesPanel.FilterText";
    private const string TopicTypeNameStateKey = "SamplesPanel.TopicTypeName";
    private const double MinColumnWeight = 0.4;

    private static readonly Action<object, object?> SyntheticSetter = (_, __) =>
        throw new InvalidOperationException("Synthetic fields are read-only.");

    private static readonly FieldMetadata OrdinalField = CreateSyntheticField(
        "Ordinal",
        typeof(long),
        input => ((SampleData)input).Ordinal);

    private static readonly FieldMetadata TopicField = CreateSyntheticField(
        "Topic",
        typeof(string),
        input => ((SampleData)input).TopicMetadata.ShortName);

    private static readonly FieldMetadata TimestampField = CreateSyntheticField(
        "Timestamp",
        typeof(DateTime),
        input => ((SampleData)input).Timestamp);

    // JSON options for sample tooltips and inline previews re-use DdsJsonOptions.Display so that
    // inactive union arms are stripped and enums appear as strings – identical to file export.
    private static readonly JsonSerializerOptions TooltipJsonOptions = DdsJsonOptions.Display;

    private readonly List<SampleData> _viewCache = new();
    private Virtualize<IndexedSample>? _virtualizeRef;
    private FieldMetadata? _delayField;
    private FieldMetadata? _sizeField;
    private readonly List<FieldMetadata> _selectedColumns = new();
    private readonly List<FieldMetadata> _availableColumns = new();
    private readonly List<ColumnLayout> _layoutColumns = new();
    private readonly Dictionary<string, double> _columnWeights = new(StringComparer.Ordinal);
    private string _filterText = string.Empty;
    private string? _filterError;
    private Timer? _refreshTimer;
    private int _currentCount;
    private int _totalCount;
    private bool _initialFilterApplied;
    private bool _trackMode = true;
    private bool _expandAll;
    private bool _showColumnPicker;
    private SampleData? _selectedSample;
    private SampleData? _pendingTrackSample;
    private int _selectedIndex = -1;
    private int _lastRequestStartIndex;
    private int _lastRequestCount = 1;
    private FieldMetadata? _sortField;
    private SortDirection _sortDirection = SortDirection.Ascending;
    private IDisposable? _addColumnSubscription;
    private IDisposable? _applyFilterSubscription;
    private Type? _currentTopicType;
    private DebouncedAction? _trackDebouncer;
    private ElementReference _gridRef;
    private bool _loadedPanelState;
    private bool _columnsInitialized;
    private bool _isColumnResizing;
    private int _resizeColumnIndex = -1;
    private double _resizeStartX;
    private double _resizeStartLeftWeight;
    private double _resizeStartRightWeight;
    private double _resizeGridWidth = 1;
    private List<string>? _savedSelectedColumnKeys;
    private Dictionary<string, double>? _savedColumnWeights;
    private Func<SampleData, bool>? _filterPredicate;
    private bool _viewDirty = true;
    private int _lastAllSamplesCount = -1;
    private Action? _viewRebuiltHandler;
    private readonly Dictionary<FieldMetadata, Type> _fieldTopicTypes = new();
    private int _columnPickerRevision;
    private bool _showExportDialog;

    [CascadingParameter]
    public PanelState? PanelState { get; set; }

    [Parameter]
    public TopicMetadata? TopicMetadata { get; set; }

    [Parameter]
    public string? InitialFilterText { get; set; }

    /// <summary>
    /// When set the panel displays this fixed list instead of the live <see cref="ISampleStore"/>.
    /// Intended for the Replay Samples browser.
    /// </summary>
    [Parameter]
    public IReadOnlyList<SampleData>? FixedSamples { get; set; }

    /// <summary>
    /// Invoked whenever the panel's filter predicate changes, passing the new predicate
    /// (or <c>null</c> when the filter is cleared).  Used by the Replay Engine to sync
    /// its playback filter with this panel.
    /// </summary>
    [Parameter]
    public EventCallback<Func<SampleData, bool>?> OnFilterChanged { get; set; }

    protected override void OnInitialized()
    {
        _addColumnSubscription = EventBroker.Subscribe<AddColumnRequestEvent>(OnAddColumnRequested);
        _applyFilterSubscription = EventBroker.Subscribe<ApplyFilterRequestEvent>(OnApplyFilterRequested);
        _trackDebouncer = new DebouncedAction(TimeSpan.FromMilliseconds(TrackDebounceMs),
            () => _ = InvokeAsync(PublishPendingTrackSample));
        _viewRebuiltHandler = () => _ = InvokeAsync(HandleViewRebuiltAsync);
        SampleStore.OnViewRebuilt += _viewRebuiltHandler;
        StartRefreshTimer();
    }

    protected override void OnParametersSet()
    {
        TryResolveTopicMetadataFromState();

        if (!_loadedPanelState && PanelState != null)
        {
            LoadPanelState();
            _loadedPanelState = true;
        }

        if (!_initialFilterApplied && TopicMetadata != null && !string.IsNullOrWhiteSpace(InitialFilterText))
        {
            _filterText = InitialFilterText;
            _initialFilterApplied = true;
        }

        var newTopicType = TopicMetadata?.TopicType;
        if (!_columnsInitialized || _currentTopicType != newTopicType)
        {
            _columnsInitialized = true;
            _currentTopicType = newTopicType;
            InitializeColumns();
            ApplyFilter();
            _viewDirty = true;
            _ = _virtualizeRef?.RefreshDataAsync();
        }
    }

    private void InitializeColumns()
    {
        _availableColumns.Clear();
        _selectedColumns.Clear();
        _fieldTopicTypes.Clear();

        if (TopicMetadata == null)
        {
            // All-topics mode: aggregate non-synthetic fields from all registered topics.
            _sizeField = null;
            _delayField = null;
            PopulateAllTopicsAvailableColumns();

            // Restore previously selected columns by matching structured names.
            if (_savedSelectedColumnKeys != null && _savedSelectedColumnKeys.Count > 0)
            {
                foreach (var key in _savedSelectedColumnKeys)
                {
                    var match = _availableColumns.FirstOrDefault(field =>
                        string.Equals(field.StructuredName, key, StringComparison.Ordinal));
                    if (match != null)
                    {
                        _selectedColumns.Add(match);
                    }
                }
            }

            RebuildLayoutColumns();
            SavePanelState();
            return;
        }

        foreach (var field in TopicMetadata.AllFields)
        {
            if (!field.IsSynthetic)
            {
                _availableColumns.Add(field);
            }
        }

        if (_savedSelectedColumnKeys != null && _savedSelectedColumnKeys.Count > 0)
        {
            foreach (var key in _savedSelectedColumnKeys)
            {
                var match = _availableColumns.FirstOrDefault(field =>
                    string.Equals(field.StructuredName, key, StringComparison.Ordinal));
                if (match != null)
                {
                    _selectedColumns.Add(match);
                }
            }

            if (_selectedColumns.Count == 0)
            {
                _selectedColumns.AddRange(_availableColumns.Take(3));
            }
        }
        else
        {
            _selectedColumns.AddRange(_availableColumns.Take(3));
        }

        _sizeField = TopicMetadata.AllFields.FirstOrDefault(field =>
            string.Equals(field.StructuredName, SizeFieldName, StringComparison.Ordinal));

        _delayField = TopicMetadata.AllFields.FirstOrDefault(field =>
            string.Equals(field.StructuredName, DelayFieldName, StringComparison.Ordinal));

        RebuildLayoutColumns();
        SavePanelState();
    }

    /// <summary>
    /// Builds _availableColumns and _fieldTopicTypes from all currently registered topics.
    /// Deduplicates by StructuredName, keeping the first-encountered field.
    /// </summary>
    private void PopulateAllTopicsAvailableColumns()
    {
        _availableColumns.Clear();
        _fieldTopicTypes.Clear();
        var seen = new HashSet<string>(StringComparer.Ordinal);

        foreach (var topic in TopicRegistry.AllTopics)
        {
            foreach (var field in topic.AllFields)
            {
                if (!field.IsSynthetic && seen.Add(field.StructuredName))
                {
                    _availableColumns.Add(field);
                    _fieldTopicTypes[field] = topic.TopicType;
                }
            }
        }
    }

    private void StartRefreshTimer()
    {
        var refreshHz = Math.Max(MinimumUiRefreshHz, Settings.UiRefreshHz);
        var interval = MillisecondsPerSecond / refreshHz;
        _refreshTimer = new Timer(_ => _ = InvokeAsync(RefreshCounts), null, interval, interval);
    }

    private Task RefreshCounts()
    {
        var previousTotal = _totalCount;
        var previousCurrent = _currentCount;
        EnsureView();
        var total = _totalCount;
        var current = _currentCount;

        if (total != previousTotal || current != previousCurrent)
        {
            _totalCount = total;
            _currentCount = current;
            _ = _virtualizeRef?.RefreshDataAsync();
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private ValueTask<ItemsProviderResult<IndexedSample>> LoadItems(ItemsProviderRequest request)
    {
        EnsureView();

        _lastRequestCount = Math.Max(1, request.Count);
        _lastRequestStartIndex = request.StartIndex;
        var available = Math.Max(0, _viewCache.Count - request.StartIndex);
        var sliceCount = Math.Min(request.Count, available);
        var items = new IndexedSample[sliceCount];
        for (var i = 0; i < sliceCount; i++)
        {
            items[i] = new IndexedSample(request.StartIndex + i, _viewCache[request.StartIndex + i]);
        }

        return new ValueTask<ItemsProviderResult<IndexedSample>>(
            new ItemsProviderResult<IndexedSample>(items, _viewCache.Count));
    }

    private void ToggleTrackMode()
    {
        _trackMode = !_trackMode;
    }

    private void ToggleColumnPicker()
    {
        if (!_showColumnPicker && TopicMetadata == null)
        {
            // Always refresh the master field list from the live topic registry before showing the picker.
            PopulateAllTopicsAvailableColumns();
            _columnPickerRevision++;
        }

        _showColumnPicker = !_showColumnPicker;
    }

    private async Task ToggleExpandAll()
    {
        _expandAll = !_expandAll;
        if (_virtualizeRef != null)
        {
            await _virtualizeRef.RefreshDataAsync();
        }
    }

    private void OpenFilterBuilder()
    {
        var filterTypeName = typeof(FilterBuilderPanel).AssemblyQualifiedName!;
        var sourcePanelId = GetPanelId();

        // Reuse an existing hidden filter panel for this samples panel (preserves its screen position).
        foreach (var existingPanel in WindowManager.ActivePanels)
        {
            if (!string.Equals(existingPanel.ComponentTypeName, filterTypeName, StringComparison.Ordinal))
            {
                continue;
            }

            if (existingPanel.ComponentState.TryGetValue(nameof(FilterBuilderPanel.LockedTargetPanelId), out var locked) &&
                string.Equals(locked?.ToString(), sourcePanelId, StringComparison.Ordinal))
            {
                existingPanel.IsHidden = false;
                existingPanel.IsMinimized = false;
                WindowManager.BringToFront(existingPanel.PanelId);
                return;
            }
        }

        var spawnState = new Dictionary<string, object>
        {
            [nameof(FilterBuilderPanel.LockedTargetPanelId)] = sourcePanelId
        };

        if (TopicMetadata != null)
        {
            spawnState[nameof(FilterBuilderPanel.PreloadedTopicMetadata)] = TopicMetadata;
        }

        var panel = WindowManager.SpawnPanel(filterTypeName, spawnState);
        panel.Title = TopicMetadata != null
            ? $"Filter [{TopicMetadata.ShortName}]"
            : "Filter [All Topics]";
        panel.Width = 1040;
        panel.Height = 480;
    }

    private async Task SaveGridSettingsAsync()
    {
        var settings = new GridSettings
        {
            FilterText = _filterText,
            ColumnKeys = _selectedColumns.Select(c => c.StructuredName).ToList(),
            ColumnWeights = new Dictionary<string, double>(_columnWeights),
            SortFieldKey = _sortField?.StructuredName,
            SortDirection = _sortDirection
        };

        var json = settings.ToJson();
        var topicLabel = TopicMetadata?.ShortName?.Replace(' ', '_') ?? "all-samples";
        var fileName = $"{topicLabel}.samplepanelsettings";
        await JSRuntime.InvokeVoidAsync("ddsMonitor.downloadTextFile", fileName, json, "application/json");
    }

    private async Task LoadGridSettingsAsync(InputFileChangeEventArgs e)
    {
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 65536);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var settings = GridSettings.FromJson(json);
            if (settings == null)
            {
                return;
            }

            if (!string.IsNullOrEmpty(settings.FilterText))
            {
                _filterText = settings.FilterText;
                ApplyFilter();
            }

            if (settings.ColumnKeys?.Count > 0)
            {
                _savedSelectedColumnKeys = settings.ColumnKeys;
            }

            if (settings.ColumnWeights?.Count > 0)
            {
                _savedColumnWeights = settings.ColumnWeights;
            }

            if (!string.IsNullOrEmpty(settings.SortFieldKey) && TopicMetadata != null)
            {
                _sortField = TopicMetadata.AllFields
                    .FirstOrDefault(f => string.Equals(f.StructuredName, settings.SortFieldKey, StringComparison.Ordinal));
                _sortDirection = settings.SortDirection;
            }

            RebuildLayoutColumns();
            SavePanelState();
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // Ignore malformed settings files.
        }
    }

    private string GetPayloadJsonSafe(SampleData sample)
    {
        try
        {
            return JsonSerializer.Serialize(sample.Payload, sample.TopicMetadata.TopicType, TooltipJsonOptions);
        }
        catch
        {
            return "(serialization error)";
        }
    }

    private async Task ApplyColumns(List<FieldMetadata> columns)
    {
        _selectedColumns.Clear();
        _selectedColumns.AddRange(columns);
        _showColumnPicker = false;
        RebuildLayoutColumns();
        SavePanelState();
        await InvokeAsync(StateHasChanged);
    }

    private Task CloseColumnPicker()
    {
        _showColumnPicker = false;
        return Task.CompletedTask;
    }

    private void OnFilterInput(ChangeEventArgs args)
    {
        _filterText = args.Value?.ToString() ?? string.Empty;
        ApplyFilter();
        SavePanelState();
    }

    private void ApplyFilter()
    {
        if (TopicMetadata == null)
        {
            // All-topics mode: filter all samples without restricting by topic type.
            if (string.IsNullOrWhiteSpace(_filterText))
            {
                _filterPredicate = null;
                _viewDirty = true;
                _filterError = null;
                NotifyFilterChanged();
                _ = _virtualizeRef?.RefreshDataAsync();
                StateHasChanged();
                return;
            }

            var allResult = FilterCompiler.Compile(_filterText, null);
            if (!allResult.IsValid || allResult.Predicate == null)
            {
                _filterError = allResult.ErrorMessage ?? "Invalid filter.";
                return;
            }

            _filterError = null;
            _filterPredicate = allResult.Predicate;
            _viewDirty = true;
            NotifyFilterChanged();
            _ = _virtualizeRef?.RefreshDataAsync();
            StateHasChanged();
            return;
        }

        Func<SampleData, bool> topicPredicate = sample => sample.TopicMetadata.TopicType == TopicMetadata.TopicType;

        if (string.IsNullOrWhiteSpace(_filterText))
        {
            _filterPredicate = topicPredicate;
            _viewDirty = true;
            _filterError = null;
            NotifyFilterChanged();
            _ = _virtualizeRef?.RefreshDataAsync();
            StateHasChanged();
            return;
        }

        var result = FilterCompiler.Compile(_filterText, TopicMetadata);
        if (!result.IsValid || result.Predicate == null)
        {
            _filterError = result.ErrorMessage ?? "Invalid filter.";
            return;
        }

        _filterError = null;
        _filterPredicate = sample => topicPredicate(sample) && result.Predicate(sample);
        _viewDirty = true;
        NotifyFilterChanged();
        _ = _virtualizeRef?.RefreshDataAsync();
        StateHasChanged();
    }

    private void ExportFilteredSamplesAsync()
    {
        _showExportDialog = true;
    }

    /// <summary>
    /// Notifies subscribers that the active filter predicate has changed.
    /// When this panel is showing a fixed sample set (Replay mode), the predicate
    /// is also published via the <see cref="IEventBroker"/> so the Replay Engine
    /// can update its own filter without a direct callback reference.
    /// </summary>
    private void NotifyFilterChanged()
    {
        _ = OnFilterChanged.InvokeAsync(_filterPredicate);

        if (FixedSamples != null)
        {
            EventBroker.Publish(new ReplayFilterChangedEvent(_filterPredicate));
        }
    }

    private async Task OnExportDialogResult(string? path)
    {
        _showExportDialog = false;
        if (string.IsNullOrWhiteSpace(path))
        {
            return;
        }

        // Capture the current view so the export runs against a consistent snapshot.
        var snapshot = _viewCache.ToList();
        try
        {
            await ExportService.ExportSamplesAsync(path, snapshot);
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Export failed: {ex.Message}");
        }
    }

    private void SelectSample(IndexedSample row, bool publishNow)
    {
        _selectedSample = row.Sample;
        _selectedIndex = row.Index;

        _ = FocusGrid();

        if (_trackMode)
        {
            if (publishNow)
            {
                EventBroker.Publish(new SampleSelectedEvent(GetPanelId(), row.Sample));
            }
            else
            {
                _pendingTrackSample = row.Sample;
                _trackDebouncer?.Trigger();
            }
        }
    }

    private void OpenDetail(SampleData sample)
    {
        var detailTypeName = typeof(DetailPanel).AssemblyQualifiedName!;
        var sourcePanelId = GetPanelId();
        var detailPanels = WindowManager.ActivePanels
            .Where(panel => string.Equals(panel.ComponentTypeName, detailTypeName, StringComparison.Ordinal))
            .ToList();

        var hasLinked = detailPanels.Any(panel => !panel.IsHidden && !panel.IsMinimized && IsLinkedDetailPanel(panel));
        var shouldLink = !hasLinked;
        var panel = FindReusableDetailPanel(detailPanels);

        if (panel == null)
        {
            panel = WindowManager.SpawnPanel(detailTypeName, new Dictionary<string, object>
            {
                [nameof(DetailPanel.Sample)] = sample,
                [nameof(DetailPanel.SourcePanelId)] = sourcePanelId,
                [nameof(DetailPanel.IsLinked)] = shouldLink
            });
            panel.Width = 546;
            // Title is based on the source panel (e.g. "All Samples"), not the sample type.
            // This keeps the title stable regardless of which topic type is displayed,
            // allowing the workspace to correctly restore window position on re-open.
            var sourcePanelState = WindowManager.ActivePanels
                .FirstOrDefault(p => string.Equals(p.PanelId, sourcePanelId, StringComparison.Ordinal));
            panel.Title = $"Detail [{sourcePanelState?.Title ?? "Samples"}]";
        }
        else
        {
            panel.IsHidden = false;
            panel.IsMinimized = false;
            panel.ComponentState[nameof(DetailPanel.Sample)] = sample;
            panel.ComponentState[nameof(DetailPanel.SourcePanelId)] = sourcePanelId;
            panel.ComponentState[nameof(DetailPanel.IsLinked)] = shouldLink;
            WindowManager.BringToFront(panel.PanelId);
        }
    }

    private static bool IsLinkedDetailPanel(PanelState panel)
    {
        if (!panel.ComponentState.TryGetValue(nameof(DetailPanel.IsLinked), out var linkedObj))
            return false;

        // ME1-C07: ComponentState values are raw bool (in-memory) or JsonElement (after workspace load)
        if (linkedObj is bool linked)
            return linked;

        if (linkedObj is System.Text.Json.JsonElement element &&
            element.ValueKind is System.Text.Json.JsonValueKind.True or System.Text.Json.JsonValueKind.False)
            return element.GetBoolean();

        return false;
    }

    private static PanelState? FindReusableDetailPanel(List<PanelState> panels)
    {
        return panels
            .Where(panel => panel.IsHidden)
            .OrderBy(GetPanelIndex)
            .FirstOrDefault();
    }

    private static int GetPanelIndex(PanelState panel)
    {
        var id = panel.PanelId;
        var dotIndex = id.LastIndexOf('.');
        if (dotIndex < 0 || dotIndex == id.Length - 1)
        {
            return int.MaxValue;
        }

        var suffix = id.Substring(dotIndex + 1);
        return int.TryParse(suffix, out var index) ? index : int.MaxValue;
    }

