@using System.Collections.Concurrent
@using System.Collections.Generic
@using System.Linq
@using System.Reflection
@using System.Runtime.InteropServices
@using System.Text.Json
@using CycloneDDS.Runtime
@using CycloneDDS.Runtime.Interop
@using CycloneDDS.Schema
@using CycloneDDS.Schema.Formatting
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.JSInterop
@implements IDisposable

@inject IEventBroker EventBroker
@inject IWindowManager WindowManager
@inject TooltipService TooltipService
@inject ContextMenuService ContextMenuService
@inject IJSRuntime JSRuntime
@inject WorkspacePersistenceService WorkspacePersistence
@inject IValueFormatterRegistry ValueFormatterRegistry

@if (_currentSample == null)
{
    <div class="panel-placeholder-content">
        <h2>Detail Panel</h2>
        <p>No sample selected.</p>
    </div>
}
else
{
    <div class="detail-panel">
        <div class="detail-panel__toolbar">
            <button type="button"
                    title="@(_linked ? "Linked \u2013 follows sample selection" : "Detached \u2013 pinned to this sample")"
                    class="detail-panel__link @(_linked ? "is-on" : string.Empty)"
                    @onclick="ToggleLinkMode">
                @if (_linked)
                {
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                }
                else
                {
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18.84 12.25l1.72-1.71a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M5.17 11.75l-1.72 1.71a5 5 0 0 0 7.07 7.07l1.72-1.71"/><line x1="8" y1="2" x2="8" y2="5"/><line x1="2" y1="8" x2="5" y2="8"/><line x1="16" y1="19" x2="16" y2="22"/><line x1="19" y1="16" x2="22" y2="16"/></svg>
                }
            </button>
            <button type="button" title="Clone this sample payload to the Sender" class="detail-panel__clone" @onclick="CloneToSend">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <span class="detail-state-badge @GetInstanceStateClass(_currentSample)"
                  title="Instance State: @GetInstanceStateTooltip(_currentSample)"></span>
        </div>

        <div class="detail-panel__tabs">
            @RenderTab(DetailTab.Tree, "Tree")
            @RenderTab(DetailTab.Table, "Table")
            @RenderTab(DetailTab.Json, "JSON")
            @RenderTab(DetailTab.SampleInfo, "Sample Info")
            @RenderTab(DetailTab.Sender, "Sender")
        </div>

        <div class="detail-panel__content">
            @switch (_activeTab)
            {
                case DetailTab.Tree:
                    @RenderTreeView()
                    break;
                case DetailTab.Table:
                    @RenderTableView()
                    break;
                case DetailTab.Json:
                    @RenderJsonView()
                    break;
                case DetailTab.SampleInfo:
                    @RenderSampleInfo()
                    break;
                case DetailTab.Sender:
                    @RenderSenderInfo()
                    break;
            }
        </div>
    </div>
}

@code {
    private const int DebounceDelayMs = 25;
    private const int RightMouseButton = 2;
    private const int MaxTreeDepth = 32;

    private SampleData? _currentSample;
    private SampleData? _pendingSample;
    private SampleData? _lastParameterSample;
    private bool _linked = true;
    private DetailTab _activeTab = DetailTab.Tree;
    private DebouncedAction? _debouncer;
    private IDisposable? _subscription;

    // Expand/collapse state – keyed by node path; persists across sample switches.
    private readonly Dictionary<string, bool> _treeExpanded = new();
    private readonly HashSet<string> _tableExpandedFields = new();

    // Active Tier 1 formatter per tree-node path (null = use Tier 2 / default rendering).
    private readonly Dictionary<string, IValueFormatter?> _selectedFormatters = new();

    [CascadingParameter]
    public PanelState? PanelState { get; set; }

    [Parameter]
    public SampleData? Sample { get; set; }

    [Parameter]
    public string? SourcePanelId { get; set; }

    [Parameter]
    public bool? IsLinked { get; set; }

    protected override void OnInitialized()
    {
        if (Sample != null)
        {
            _currentSample = Sample;
        }

        _linked = IsLinked ?? Sample == null;
        PersistPanelState();

        if (!string.IsNullOrWhiteSpace(SourcePanelId))
        {
            _subscription = EventBroker.Subscribe<SampleSelectedEvent>(OnSampleSelected);
        }

        _debouncer = new DebouncedAction(TimeSpan.FromMilliseconds(DebounceDelayMs),
            () => _ = InvokeAsync(ApplyPendingSample));
    }

    protected override void OnParametersSet()
    {
        if (IsLinked.HasValue)
        {
            _linked = IsLinked.Value;
            PersistPanelState();
        }

        if (Sample != null && Sample != _lastParameterSample)
        {
            _lastParameterSample = Sample;
            _currentSample = Sample;
        }
    }

    private void OnSampleSelected(SampleSelectedEvent message)
    {
        if (!_linked)
        {
            return;
        }

        if (!string.Equals(message.SourcePanelId, SourcePanelId, StringComparison.Ordinal))
        {
            return;
        }

        _pendingSample = message.Sample;
        _debouncer?.Trigger();
    }

    private Task ApplyPendingSample()
    {
        _currentSample = _pendingSample;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ToggleLinkMode()
    {
        _linked = !_linked;
        PersistPanelState();
        // ME1-C07: ensure link-state change is immediately persisted to disk
        WorkspacePersistence.RequestSave();
    }

    private void PersistPanelState()
    {
        if (PanelState == null)
        {
            return;
        }

        PanelState.ComponentState[nameof(IsLinked)] = _linked;
    }

    private RenderFragment RenderTab(DetailTab tab, string label) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", _activeTab == tab ? "detail-panel__tab is-active" : "detail-panel__tab");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => _activeTab = tab));
        builder.AddContent(sequence++, label);
        builder.CloseElement();
    };

    private RenderFragment RenderTreeView() => builder =>
    {
        if (_currentSample == null)
        {
            return;
        }

        var traversal = new HashSet<object>(ReferenceEqualityComparer.Instance);
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "detail-tree");
        builder.AddContent(2, RenderNode(_currentSample.Payload, _currentSample.TopicMetadata.ShortName, string.Empty, traversal, 0));
        builder.CloseElement();
    };

    private RenderFragment RenderTableView() => @<text>
        @if (_currentSample != null)
        {
            <table class="detail-table">
                <thead>
                    <tr>
                        <th>Field</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var payload = _currentSample.Payload; }
                    @foreach (var field in _currentSample.TopicMetadata.AllFields.Where(meta => !meta.IsSynthetic && IsUnionArmVisible(meta, payload)))
                    {
                        var value = field.Getter(payload);
                        var isExpandable = IsTableFieldExpandable(value);
                        var fieldName = field.StructuredName;
                        var isExpanded = isExpandable && _tableExpandedFields.Contains(fieldName);

                        <tr>
                            <td>
                                @if (isExpandable)
                                {
                                    <button type="button" class="detail-table__toggle" @onclick="() => ToggleTableField(fieldName)">
                                        @(isExpanded ? "\u25bc" : "\u25ba")
                                    </button>
                                }
                                @field.StructuredName
                            </td>
                            <td>@RenderValue(value)</td>
                        </tr>

                        @if (isExpanded && value != null)
                        {
                            var arr = ToElementArray(value);
                            if (arr != null)
                            {
                                for (int i = 0; i < arr.Length; i++)
                                {
                                    var elemVal = arr.GetValue(i);
                                    var isUnionElem = elemVal != null && elemVal.GetType().GetCustomAttribute<DdsUnionAttribute>() != null;
                                    var elemName = $"{fieldName}[{i}]";
                                    var isElemExpanded = isUnionElem && _tableExpandedFields.Contains(elemName);

                                    <tr class="detail-table__element-row">
                                        <td class="detail-table__element-name">
                                            @if (isUnionElem)
                                            {
                                                var capturedElemName = elemName;
                                                <button type="button" class="detail-table__toggle" @onclick="() => ToggleTableField(capturedElemName)">
                                                    @(isElemExpanded ? "\u25bc" : "\u25ba")
                                                </button>
                                            }
                                            [@i]
                                        </td>
                                        <td>
                                            @if (isUnionElem)
                                            {
                                                var uInfo = GetUnionInfo(elemVal!);
                                                @RenderValue(uInfo.Discriminator)
                                            }
                                            else
                                            {
                                                @RenderValue(elemVal)
                                            }
                                        </td>
                                    </tr>

                                    @if (isUnionElem && isElemExpanded && elemVal != null)
                                    {
                                        var uInfo = GetUnionInfo(elemVal);
                                        if (uInfo.ActiveArm != null)
                                        {
                                            <tr class="detail-table__element-row detail-table__element-row--nested">
                                                <td class="detail-table__element-name detail-table__element-name--nested">
                                                    @uInfo.ActiveArm.Name
                                                </td>
                                                <td>@RenderValue(uInfo.ArmValue)</td>
                                            </tr>
                                        }
                                    }
                                }
                            }
                        }
                    }
                </tbody>
            </table>
        }
    </text>;

    private RenderFragment RenderJsonView() => builder =>
    {
        if (_currentSample == null)
        {
            return;
        }

        var payload = _currentSample.Payload;
        var json = SerializePayload(payload);
        if (json == null)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "detail-panel__empty");
            builder.AddContent(2, "JSON serialization failed.");
            builder.CloseElement();
            return;
        }

        var html = JsonSyntaxHighlighter.ToHtml(json);
        builder.OpenElement(3, "pre");
        builder.AddAttribute(4, "class", "detail-json");
        builder.AddContent(5, (MarkupString)html);
        builder.CloseElement();
    };

    private RenderFragment RenderSampleInfo() => builder =>
    {
        if (_currentSample == null)
        {
            return;
        }

        var info = _currentSample.SampleInfo;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "detail-info");
        builder.AddContent(2, $"Global Ordinal: {_currentSample.Ordinal}");
        builder.AddMarkupContent(3, "<br />");
        builder.AddContent(4, $"Incoming Timestamp: {_currentSample.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss.fffffff")}");
        builder.AddMarkupContent(5, "<br />");
        builder.AddContent(6, $"Domain ID: {_currentSample.DomainId}");
        builder.AddMarkupContent(7, "<br />");
        builder.AddContent(8, $"Partition: {(string.IsNullOrEmpty(_currentSample.PartitionName) ? "<default>" : _currentSample.PartitionName)}");
        builder.AddMarkupContent(9, "<br />");
        builder.AddContent(10, $"Instance: {info.InstanceState}");
        builder.AddMarkupContent(11, "<br />");
        builder.AddContent(12, $"Sample: {info.SampleState}");
        builder.AddMarkupContent(13, "<br />");
        builder.AddContent(14, $"View: {info.ViewState}");
        builder.AddMarkupContent(15, "<br />");
        builder.AddContent(16, $"SourceTimestamp: {FormatSourceTimestamp(info.SourceTimestamp)}");
        builder.CloseElement();
    };

    private RenderFragment RenderSenderInfo() => builder =>
    {
        if (_currentSample == null)
        {
            return;
        }

        var sender = _currentSample.Sender;
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "detail-info");
        if (sender == null)
        {
            builder.AddContent(2, "No sender metadata.");
        }
        else
        {
            builder.AddContent(2, $"ProcessId: {sender.ProcessId}");
            builder.AddMarkupContent(3, "<br />");
            builder.AddContent(4, $"Machine: {sender.MachineName}");
            builder.AddMarkupContent(5, "<br />");
            builder.AddContent(6, $"IP: {sender.IpAddress}");
        }
        builder.CloseElement();
    };

    private static string FormatSourceTimestamp(long nanoseconds)
    {
        if (nanoseconds <= 0 || nanoseconds == long.MaxValue)
        {
            return "Unknown";
        }

        return DateTime.UnixEpoch.AddTicks(nanoseconds / 100).ToLocalTime()
            .ToString("yyyy-MM-dd HH:mm:ss.fffffff");
    }

    private RenderFragment RenderNode(object? value, string label, string path, HashSet<object> traversal, int depth) => builder =>
    {
        var sequence = 0;
        var type = value?.GetType();
        var isReferenceType = type != null && !type.IsValueType;
        var isCycle = isReferenceType && traversal.Contains(value!);
        var isMaxDepth = depth >= MaxTreeDepth;
        var isLeaf = type == null || IsLeafType(type) || isCycle || isMaxDepth;
        var isRoot = string.IsNullOrEmpty(path) && _currentSample != null &&
            string.Equals(label, _currentSample.TopicMetadata.ShortName, StringComparison.Ordinal);
        var nextPath = isRoot
            ? string.Empty
            : (string.IsNullOrEmpty(path) ? label : $"{path}.{label}");
        var displayValue = value;
        var displayType = type;

        if (isCycle)
        {
            displayValue = "(cycle)";
            displayType = typeof(string);
        }
        else if (isMaxDepth)
        {
            displayValue = "(max depth)";
            displayType = typeof(string);
        }
        else if (!isLeaf && type != null && value != null &&
                 type.GetCustomAttribute<DdsUnionAttribute>() != null)
        {
            // ME2-T06: show discriminator value as the collapsed node label for union types.
            var uInfo = GetUnionInfo(value);
            displayValue = uInfo.Discriminator;
            displayType = uInfo.Discriminator?.GetType() ?? typeof(string);
        }

        // Determine whether this non-leaf node is array-like (for default-collapsed behaviour).
        var isArrayLike = !isLeaf && type != null &&
            (type.IsArray ||
             IsFixedBufferValueType(type) ||
             IsInlineArrayValueType(type) ||
             (type.IsGenericType && type.GetGenericTypeDefinition() == typeof(List<>)));

        // Non-root, non-leaf nodes are user-collapsible.  Arrays/buffers start collapsed.
        var isToggleable = !isLeaf && !isRoot;
        var isExpanded = !isToggleable || IsTreeNodeExpanded(nextPath, isArrayLike);

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "detail-tree__node");
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "detail-tree__row");

        // Expand/collapse toggle button for collapsible nodes.
        if (isToggleable)
        {
            var togglePath = nextPath;
            var toggleIsArray = isArrayLike;
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", "detail-tree__toggle");
            builder.AddAttribute(sequence++, "onclick",
                EventCallback.Factory.Create(this, () => ToggleTreeNode(togglePath, toggleIsArray)));
            builder.AddContent(sequence++, isExpanded ? "\u25bc" : "\u25ba");
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "detail-tree__label");
        builder.AddContent(sequence++, label);
        builder.CloseElement();

        // Render the value span — use formatted token rendering for types with GetFormatTokens().
        var fmtMethodForNode = !isCycle && !isMaxDepth && displayType != null
            ? GetFormatTokensMethod(displayType)
            : null;

        if (fmtMethodForNode != null && displayValue != null)
        {
            builder.AddContent(sequence++, RenderFormattedTokenValue(displayValue, fmtMethodForNode, nextPath));
        }
        else
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", GetValueClass(displayType));
            builder.AddContent(sequence++, RenderValue(displayValue));
            builder.CloseElement();
        }

        if (isLeaf)
        {
            RenderPin(builder, ref sequence, nextPath);
            RenderTextViewButton(builder, ref sequence, value);
        }

        builder.CloseElement();

        var addedToTraversal = false;
        if (!isLeaf && isReferenceType && value != null)
        {
            addedToTraversal = traversal.Add(value);
        }

        if (!isLeaf && value != null && isExpanded)
        {
            var nonNullType = type!;
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "detail-tree__children");

            if (nonNullType.IsArray)
            {
                // Render each array element as an indexed child node.
                var arr = (Array)value;
                for (int i = 0; i < arr.Length; i++)
                {
                    var idx = i;
                    builder.AddContent(sequence++, RenderNode(arr.GetValue(idx), $"[{idx}]", nextPath, traversal, depth + 1));
                }
            }
            else if (IsFixedBufferValueType(nonNullType))
            {
                // Compiler-generated FixedBuffer struct — expand as indexed byte/element children.
                var elements = ReadFixedBufferElements(value, nonNullType);
                for (int i = 0; i < elements.Length; i++)
                {
                    var idx = i;
                    builder.AddContent(sequence++, RenderNode(elements.GetValue(idx), $"[{idx}]", nextPath, traversal, depth + 1));
                }
            }
            else if (IsInlineArrayValueType(nonNullType))
            {
                // ME1-C06: [InlineArray(N)] struct — expand as indexed element children.
                var elements = ReadInlineArrayElements(value, nonNullType);
                for (int i = 0; i < elements.Length; i++)
                {
                    var idx = i;
                    builder.AddContent(sequence++, RenderNode(elements.GetValue(idx), $"[{idx}]", nextPath, traversal, depth + 1));
                }
            }
            else if (nonNullType.IsGenericType &&
                     nonNullType.GetGenericTypeDefinition() == typeof(List<>))
            {
                // List<T> — iterate via the IEnumerable interface.
                var list = (System.Collections.IList)value;
                for (int i = 0; i < list.Count; i++)
                {
                    var idx = i;
                    builder.AddContent(sequence++, RenderNode(list[idx], $"[{idx}]", nextPath, traversal, depth + 1));
                }
            }
            else
            {
                // ── ME1-T08: For [DdsUnion] structs, show only the active arm ─────────
                if (nonNullType.GetCustomAttribute<DdsUnionAttribute>() != null)
                {
                    // Find the discriminator member and its current value.
                    MemberInfo? discMember = null;
                    foreach (var m in GetMembers(nonNullType))
                    {
                        if (m.GetCustomAttribute<DdsDiscriminatorAttribute>() != null)
                        {
                            discMember = m;
                            break;
                        }
                    }

                    object? discValue = discMember != null ? GetMemberValue(discMember, value) : null;

                    // Determine whether any explicit case matches the discriminator value.
                    bool anyExplicitMatch = GetMembers(nonNullType)
                        .Where(m => m.GetCustomAttribute<DdsCaseAttribute>() != null)
                        .Any(m => UnionValuesEqualTree(m.GetCustomAttribute<DdsCaseAttribute>()!.Value, discValue));

                    foreach (var member in GetMembers(nonNullType))
                    {
                        // Always show the discriminator.
                        if (member.GetCustomAttribute<DdsDiscriminatorAttribute>() != null)
                        {
                            var mv = GetMemberValue(member, value);
                            builder.AddContent(sequence++, RenderNode(mv, member.Name, nextPath, traversal, depth + 1));
                            continue;
                        }

                        var caseAttr = member.GetCustomAttribute<DdsCaseAttribute>();
                        var defaultCaseAttr = member.GetCustomAttribute<DdsDefaultCaseAttribute>();

                        if (caseAttr != null)
                        {
                            // Show only the arm whose case value equals the discriminator.
                            if (!UnionValuesEqualTree(caseAttr.Value, discValue))
                                continue;
                        }
                        else if (defaultCaseAttr != null)
                        {
                            // Show default arm only when no explicit arm matched.
                            if (anyExplicitMatch)
                                continue;
                        }
                        else
                        {
                            // Field in a union without case marker – skip.
                            continue;
                        }

                        var memberValue = GetMemberValue(member, value);
                        builder.AddContent(sequence++, RenderNode(memberValue, member.Name, nextPath, traversal, depth + 1));
                    }
                }
                else
                {
                    foreach (var member in GetMembers(nonNullType))
                    {
                        var memberValue = GetMemberValue(member, value);
                        builder.AddContent(sequence++, RenderNode(memberValue, member.Name, nextPath, traversal, depth + 1));
                    }
                }
            }

            builder.CloseElement();
        }

        if (addedToTraversal)
        {
            traversal.Remove(value!);
        }

        builder.CloseElement();
    };

    private void RenderPin(RenderTreeBuilder builder, ref int sequence, string path)
    {
        if (string.IsNullOrWhiteSpace(SourcePanelId))
        {
            return;
        }

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "detail-tree__pin");
        builder.AddAttribute(sequence++, "onclick",
            EventCallback.Factory.Create(this, () => AddColumn(path)));
        builder.AddContent(sequence++, "+");
        builder.CloseElement();
    }

    private void RenderTextViewButton(RenderTreeBuilder builder, ref int sequence, object? value)
    {
        if (value is not string text)
        {
            return;
        }

        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "detail-tree__textview");
        builder.AddAttribute(sequence++, "onclick",
            EventCallback.Factory.Create(this, () => OpenTextView(text)));
        builder.AddContent(sequence++, "Open");
        builder.CloseElement();
    }

    private void AddColumn(string path)
    {
        if (string.IsNullOrWhiteSpace(SourcePanelId))
        {
            return;
        }

        EventBroker.Publish(new AddColumnRequestEvent(SourcePanelId, path));
    }

    private void OpenTextView(string text)
    {
        var panel = WindowManager.SpawnPanel(typeof(TextViewPanel).FullName!, new Dictionary<string, object>
        {
            [nameof(TextViewPanel.Title)] = "Text View",
            [nameof(TextViewPanel.Content)] = text
        });

        panel.Title = "Text View";
    }

    private RenderFragment RenderValue(object? value) => builder =>
    {
        if (value == null)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "detail-tree__value is-null");
            builder.AddContent(2, "null");
            builder.CloseElement();
            return;
        }

        if (value is string text)
        {
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "detail-tree__value is-string");
            builder.AddAttribute(2, "onmouseenter",
                EventCallback.Factory.Create<MouseEventArgs>(this, args => ShowJsonTooltip(text, args)));
            builder.AddAttribute(3, "onmouseleave",
                EventCallback.Factory.Create(this, HideTooltip));
            builder.AddAttribute(4, "onmousedown",
                EventCallback.Factory.Create<MouseEventArgs>(this, args => HandleValueMouseDown(text, true, args)));
            builder.AddAttribute(5, "oncontextmenu:preventDefault", true);
            builder.AddContent(6, text);
            builder.CloseElement();
        }
        else if (value != null && IsFixedStringType(value.GetType()))
        {
            // FixedStringN: render as a string value showing the actual text content.
            var fsText = value.ToString() ?? string.Empty;
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "detail-tree__value is-string");
            builder.AddAttribute(2, "onmousedown",
                EventCallback.Factory.Create<MouseEventArgs>(this, args => HandleValueMouseDown(fsText, false, args)));
            builder.AddAttribute(3, "oncontextmenu:preventDefault", true);
            builder.AddContent(4, fsText);
            builder.CloseElement();
        }
        else if (value is Array arr)
        {
            // Show a compact summary for array nodes; children are rendered separately.
            builder.OpenElement(6, "span");
            builder.AddAttribute(7, "class", "detail-tree__value detail-tree__value--array");
            builder.AddContent(8, $"[{arr.Length}]");
            builder.CloseElement();
        }
        else if (value != null && value.GetType().IsGenericType &&
                 value.GetType().GetGenericTypeDefinition() == typeof(List<>))
        {
            var list = (System.Collections.IList)value;
            builder.OpenElement(6, "span");
            builder.AddAttribute(7, "class", "detail-tree__value detail-tree__value--array");
            builder.AddContent(8, $"[{list.Count}]");
            builder.CloseElement();
        }
        else if (value != null && IsFixedBufferValueType(value.GetType()))
        {
            // Fixed-buffer compiler struct — show element count from size.
            int byteSize = Marshal.SizeOf(value.GetType());
            var elemField = value.GetType().GetField("FixedElementField",
                BindingFlags.Public | BindingFlags.Instance);
            int elemSize = elemField != null ? Marshal.SizeOf(elemField.FieldType) : 1;
            builder.OpenElement(6, "span");
            builder.AddAttribute(7, "class", "detail-tree__value detail-tree__value--array");
            builder.AddContent(8, $"[{byteSize / elemSize}]");
            builder.CloseElement();
        }
        else if (value != null && GetFormatTokensMethod(value.GetType()) != null)
        {
            // Tier 2 duck-typed GetFormatTokens(): render inline token sequence (table view, no path context).
            var fmtMethod = GetFormatTokensMethod(value.GetType())!;
            var fmtTokens = ((IEnumerable<FormattedToken>)(fmtMethod.Invoke(value, null)
                ?? Array.Empty<FormattedToken>())).ToList();
            var plainText = string.Concat(fmtTokens.Select(t => t.Text));
            var capturedText = plainText;
            builder.OpenElement(0, "span");
            builder.AddAttribute(1, "class", "detail-tree__value detail-tree__value--formatted");
            builder.AddAttribute(2, "onmousedown",
                EventCallback.Factory.Create<MouseEventArgs>(this, args => HandleValueMouseDown(capturedText, false, args)));
            builder.AddAttribute(3, "oncontextmenu:preventDefault", true);
            var fmtSeq = 4;
            foreach (var token in fmtTokens)
            {
                builder.OpenElement(fmtSeq++, "span");
                builder.AddAttribute(fmtSeq++, "class", GetTokenClass(token.Type));
                builder.AddContent(fmtSeq++, token.Text);
                builder.CloseElement();
            }
            builder.CloseElement();
        }
        else
        {
            var content = value is bool boolVal
                ? (boolVal ? "true" : "false")
                : value.ToString() ?? string.Empty;
            builder.OpenElement(6, "span");
            builder.AddAttribute(7, "class", GetValueClass(value.GetType()));
            builder.AddAttribute(8, "onmousedown",
                EventCallback.Factory.Create<MouseEventArgs>(this, args => HandleValueMouseDown(content, false, args)));
            builder.AddAttribute(9, "oncontextmenu:preventDefault", true);
            builder.AddContent(10, content);
            builder.CloseElement();
        }
    };

    /// <summary>
    /// Renders a value with full Tier 2 (GetFormatTokens) token highlighting AND Tier 1 formatter
    /// selection support.  Called from <see cref="RenderNode"/> when a path is available.
    /// </summary>
    private RenderFragment RenderFormattedTokenValue(object value, MethodInfo fmtMethod, string path) => builder =>
    {
        var sequence = 0;

        // Determine which tokens to render: Tier 1 selected formatter wins over Tier 2 default.
        IEnumerable<FormattedToken> tokens;
        if (_selectedFormatters.TryGetValue(path, out var activeFmt) && activeFmt != null)
        {
            tokens = activeFmt.FormatTokens(value);
        }
        else
        {
            tokens = (IEnumerable<FormattedToken>)(fmtMethod.Invoke(value, null)
                ?? Array.Empty<FormattedToken>());
        }

        var tokenList = tokens.ToList();
        var plainText = string.Concat(tokenList.Select(t => t.Text));
        var capturedPath = path;
        var capturedValue = value;
        var capturedText = plainText;

        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "detail-tree__value detail-tree__value--formatted");
        builder.AddAttribute(sequence++, "onmousedown",
            EventCallback.Factory.Create<MouseEventArgs>(this,
                args => HandleFormattedValueMouseDown(capturedValue, capturedPath, capturedText, args)));
        builder.AddAttribute(sequence++, "oncontextmenu:preventDefault", true);

        foreach (var token in tokenList)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", GetTokenClass(token.Type));
            builder.AddContent(sequence++, token.Text);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private void HandleFormattedValueMouseDown(object value, string path, string plainText, MouseEventArgs args)
    {
        if (args.Button != RightMouseButton)
        {
            return;
        }

        OpenFormatterContextMenu(value, path, plainText, args);
    }

    private void OpenFormatterContextMenu(object value, string path, string plainText, MouseEventArgs args)
    {
        var items = new List<ContextMenuItem>
        {
            new("Copy to Clipboard", null, () => CopyToClipboardAsync(plainText))
        };

        var formatters = ValueFormatterRegistry.GetFormatters(value.GetType(), value);
        if (formatters.Count > 0)
        {
            items.Add(new("── View As ──", null, null));

            var capturedPath0 = path;
            items.Add(new("Default", null, () =>
            {
                _selectedFormatters.Remove(capturedPath0);
                _ = InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            }));

            foreach (var fmt in formatters)
            {
                var capturedFmt = fmt;
                var capturedPath1 = path;
                items.Add(new(capturedFmt.DisplayName, null, () =>
                {
                    _selectedFormatters[capturedPath1] = capturedFmt;
                    _ = InvokeAsync(StateHasChanged);
                    return Task.CompletedTask;
                }));
            }
        }

        ContextMenuService.Show(new ContextMenuState(items, args.ClientX, args.ClientY));
    }

    private void ShowJsonTooltip(string text, MouseEventArgs args)
    {
        if (!JsonTooltipParser.TryFormatJson(text, out var formatted))
        {
            return;
        }

        var html = JsonSyntaxHighlighter.ToHtml(formatted);
        TooltipService.Show(new TooltipState(html, args.ClientX + 12, args.ClientY + 12));
    }

    private void HideTooltip()
    {
        TooltipService.Hide();
    }

    private void OpenValueContextMenu(string text, bool allowTextView, MouseEventArgs args)
    {
        var items = new List<ContextMenuItem>
        {
            new("Copy to Clipboard", null, () => CopyToClipboardAsync(text))
        };

        if (allowTextView)
        {
            items.Add(new("Show in Separate Window", null, () =>
            {
                OpenTextView(text);
                return Task.CompletedTask;
            }));
        }

        ContextMenuService.Show(new ContextMenuState(items, args.ClientX, args.ClientY));
    }

    private void HandleValueMouseDown(string text, bool allowTextView, MouseEventArgs args)
    {
        if (args.Button != RightMouseButton)
        {
            return;
        }

        OpenValueContextMenu(text, allowTextView, args);
    }

    private Task CopyToClipboardAsync(string text)
    {
        return JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text).AsTask();
    }

    private static string? SerializePayload(object payload)
    {
        try
        {
            return JsonSerializer.Serialize(payload, payload.GetType(), DdsJsonOptions.Display);
        }
        catch (Exception)
        {
            return null;
        }
    }

    private void CloneToSend()
    {
        if (_currentSample == null)
        {
            return;
        }

        var payload = _currentSample.Payload;
        try
        {
            var json = JsonSerializer.Serialize(payload, payload.GetType(), DdsJsonOptions.Export);
            var clone = JsonSerializer.Deserialize(json, payload.GetType(), DdsJsonOptions.Export);
            if (clone != null)
            {
                EventBroker.Publish(new CloneAndSendRequestEvent(_currentSample.TopicMetadata, clone));
            }
        }
        catch (Exception)
        {
        }
    }

    private static IEnumerable<MemberInfo> GetMembers(Type type)
    {
        const BindingFlags flags = BindingFlags.Public | BindingFlags.Instance;
        foreach (var field in type.GetFields(flags))
        {
            if (!field.IsStatic)
            {
                yield return field;
            }
        }

        foreach (var property in type.GetProperties(flags))
        {
            if (property.GetMethod != null && property.GetIndexParameters().Length == 0)
            {
                yield return property;
            }
        }
    }

    private static object? GetMemberValue(MemberInfo member, object target)
    {
        return member switch
        {
            FieldInfo field => field.GetValue(target),
            PropertyInfo property => property.GetValue(target),
            _ => null
        };
    }

    /// <summary>
    /// Compares two values for union discriminator matching.
    /// Handles cross-type cases (e.g. int discriminator vs enum case value) via Int64 conversion.
    /// </summary>
    private static bool UnionValuesEqualTree(object a, object? b)
    {
        if (b == null) return false;
        if (a.Equals(b)) return true;
        try { return Convert.ToInt64(a) == Convert.ToInt64(b); }
        catch { return false; }
    }

    private static bool IsLeafType(Type type)
    {
        if (type.IsPrimitive || type.IsEnum)
        {
            return true;
        }

        if (type == typeof(string) || type == typeof(decimal) || type == typeof(DateTime) ||
               type == typeof(DateTimeOffset) || type == typeof(TimeSpan) || type == typeof(Guid))
        {
            return true;
        }

        // Types with a duck-typed GetFormatTokens() method render inline as token sequences.
        if (GetFormatTokensMethod(type) != null)
        {
            return true;
        }

        // FixedStringN types are string-like scalars – render their text, not their struct internals.
        return IsFixedStringType(type);
    }

    private static bool IsFixedStringType(Type type)
    {
        return type == typeof(FixedString32)
            || type == typeof(FixedString64)
            || type == typeof(FixedString128)
            || type == typeof(FixedString256);
    }

    private static string GetValueClass(Type? type)
    {
        if (type == null)
        {
            return "detail-tree__value is-null";
        }

        if (type == typeof(string) || IsFixedStringType(type))
        {
            return "detail-tree__value is-string";
        }

        if (type == typeof(bool))
        {
            return "detail-tree__value is-bool";
        }

        if (type.IsEnum)
        {
            return "detail-tree__value is-enum";
        }

        if (type.IsPrimitive || type == typeof(decimal))
        {
            return "detail-tree__value is-number";
        }

        return "detail-tree__value";
    }

    /// <summary>Maps a <see cref="TokenType"/> to the appropriate CSS class for syntax highlighting.</summary>
    private static string GetTokenClass(TokenType tokenType) => tokenType switch
    {
        TokenType.Number      => "detail-tree__value is-number",
        TokenType.String      => "detail-tree__value is-string",
        TokenType.Boolean     => "detail-tree__value is-bool",
        TokenType.Enum        => "detail-tree__value is-enum",
        TokenType.Keyword     => "detail-tree__value is-keyword",
        TokenType.Punctuation => "detail-tree__value is-punctuation",
        TokenType.Null        => "detail-tree__value is-null",
        _                     => "detail-tree__value",
    };

    /// <summary>
    /// Per-type reflection cache for the duck-typed <c>GetFormatTokens()</c> method.
    /// Returns <c>null</c> when the type does not implement the method.
    /// </summary>
    private static readonly ConcurrentDictionary<Type, MethodInfo?> _fmtTokensMethodCache = new();

    private static MethodInfo? GetFormatTokensMethod(Type type)
        => _fmtTokensMethodCache.GetOrAdd(type, t => t.GetMethod("GetFormatTokens"));

    // ─────────────────────────────────────────────────────────────────────
    // Union rendering helpers (ME2-T06 + ME2-T22-B: cached reflection)
    // ─────────────────────────────────────────────────────────────────────

    /// <summary>
    /// Structural metadata for a union type, cached to avoid repeated reflection.
    /// </summary>
    private sealed record UnionMeta(
        MemberInfo? DiscriminatorMember,
        IReadOnlyList<(MemberInfo Member, object CaseValue)> CaseArms,
        MemberInfo? DefaultArm);

    /// <summary>
    /// Per-type cache used by <see cref="GetUnionInfo"/> to avoid scanning attributes
    /// on every render cycle (ME2-T22-B).
    /// </summary>
    private static readonly ConcurrentDictionary<Type, UnionMeta> _unionMetaCache = new();

    private static UnionMeta BuildUnionMeta(Type type)
    {
        MemberInfo? discMember = null;
        MemberInfo? defaultArm = null;
        var caseArms = new List<(MemberInfo, object)>();

        foreach (var m in GetMembers(type))
        {
            if (m.GetCustomAttribute<DdsDiscriminatorAttribute>() != null)
            {
                discMember = m;
                continue;
            }

            var caseAttr = m.GetCustomAttribute<DdsCaseAttribute>();
            if (caseAttr != null)
            {
                caseArms.Add((m, caseAttr.Value));
                continue;
            }

            if (m.GetCustomAttribute<DdsDefaultCaseAttribute>() != null)
            {
                defaultArm = m;
            }
        }

        return new UnionMeta(discMember, caseArms, defaultArm);
    }

    private static (object? Discriminator, MemberInfo? ActiveArm, object? ArmValue) GetUnionInfo(object unionObj)
    {
        var type = unionObj.GetType();

        // Use cached structural metadata – avoids repeated GetCustomAttribute calls (ME2-T22-B).
        var meta = _unionMetaCache.GetOrAdd(type, BuildUnionMeta);

        var discValue = meta.DiscriminatorMember != null
            ? GetMemberValue(meta.DiscriminatorMember, unionObj)
            : null;

        foreach (var (member, caseValue) in meta.CaseArms)
        {
            if (UnionValuesEqualTree(caseValue, discValue))
                return (discValue, member, GetMemberValue(member, unionObj));
        }

        if (meta.DefaultArm != null)
            return (discValue, meta.DefaultArm, GetMemberValue(meta.DefaultArm, unionObj));

        return (discValue, null, null);
    }

    private bool IsUnionArmVisible(FieldMetadata field, object payload)
    {
        // Non-arm fields (discriminator fields, plain fields) are always visible.
        if (field.DependentDiscriminatorPath == null)
        {
            return true;
        }

        // Locate the discriminator field to read the current value.
        var discField = _currentSample?.TopicMetadata.AllFields
            .FirstOrDefault(f => f.StructuredName == field.DependentDiscriminatorPath);
        if (discField == null)
        {
            return true;
        }

        var discValue = discField.Getter(payload);

        if (field.IsDefaultUnionCase)
        {
            // Show default arm only when no explicit arm matches.
            return !_currentSample!.TopicMetadata.AllFields.Any(f =>
                f.DependentDiscriminatorPath == field.DependentDiscriminatorPath
                && !f.IsDefaultUnionCase
                && f.ActiveWhenDiscriminatorValue != null
                && UnionValuesEqualTree(f.ActiveWhenDiscriminatorValue, discValue));
        }

        return field.ActiveWhenDiscriminatorValue != null
               && UnionValuesEqualTree(field.ActiveWhenDiscriminatorValue, discValue);
    }

