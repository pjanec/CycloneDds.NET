    private static string GetInstanceStateClass(SampleData? sample)
    {
        if (sample == null) return string.Empty;
        return sample.SampleInfo.InstanceState switch
        {
            DdsInstanceState.Alive            => "detail-state-badge--alive",
            DdsInstanceState.NotAliveDisposed => "detail-state-badge--disposed",
            _                                 => "detail-state-badge--no-writers"
        };
    }

    private static string GetInstanceStateTooltip(SampleData? sample)
    {
        if (sample == null) return string.Empty;
        return sample.SampleInfo.InstanceState switch
        {
            DdsInstanceState.Alive            => "Alive",
            DdsInstanceState.NotAliveDisposed => "Disposed (Not Alive)",
            _                                 => "No Writers"
        };
    }

